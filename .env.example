NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
RESEND_API_KEY=re_your_api_key
# Sender address — must be a verified domain in your Resend account
RESEND_FROM_EMAIL=noreply@staatwright.co.za
CONTACT_EMAIL=contact@staatwright.co.za
NEXT_PUBLIC_APP_URL=https://staatwright.co.za
# Postmark inbound webhook token — set in Postmark → Servers → your server → Settings → Webhooks
# Copy the same value into your Supabase Function secrets as POSTMARK_WEBHOOK_TOKEN
POSTMARK_WEBHOOK_TOKEN=your-postmark-webhook-token
# OpenAI — used for OCR on bills and expense slips (GPT-4o Vision)
OPENAI_API_KEY=your-openai-api-key-here
